# Backend Environment Variables
# Rename this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/nolyss

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_minimum_32_chars

# Email Configuration (for verification and password reset)
# If not configured, tokens will be displayed in response (dev only)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@nolyss.com

# Frontend URL (for email links)
CLIENT_URL=http://localhost:3000

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ORIGIN=http://localhost:3000
